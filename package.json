{
  "name": "mqtttree",
  "version": "0.1.7",
  "description": "Windows-first MQTT topic tree workspace for TLS and secure WebSocket connections.",
  "author": "MQTTree contributors",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:integration": "powershell -ExecutionPolicy Bypass -File scripts/test-emqx.ps1",
    "test:watch": "vitest",
    "package": "npm run build && electron-builder --win portable",
    "package:nsis": "npm run build && electron-builder --win nsis",
    "package:dir": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.mqtttree.app",
    "productName": "MQTTree",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.3",
    "mqtt": "^5.15.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
